  "property_tests": [
    {
      "nome": "OBJ_rotina_implica_OB_nao_OC",
      "tipo": "invariante",
      "descricao": "Se violacao_rotina=true, resultado NUNCA pode ser O-C",
      "etapa": 4,
      "input": {
        "objetivo_consistente_normas": false,
        "violacao_rotina": true
      },
      "propriedade": "codigo != 'O-C'"
    },
    {
      "nome": "OBJ_sem_rotina_implica_OC_nao_OB",
      "tipo": "invariante",
      "descricao": "Se violacao_rotina=false e normas violadas, resultado NUNCA pode ser O-B",
      "etapa": 4,
      "input": {
        "objetivo_consistente_normas": false,
        "violacao_rotina": false
      },
      "propriedade": "codigo != 'O-B'"
    },
    {
      "nome": "PER_sem_capacidade_implica_PB_nao_PD",
      "tipo": "invariante",
      "descricao": "Se capacidade_sensorial=false, resultado NUNCA pode ser P-D ou P-G",
      "etapa": 3,
      "input": {
        "avaliacao_correta": false,
        "capacidade_sensorial": false
      },
      "propriedade": "codigo != 'P-D' && codigo != 'P-G'"
    },
    {
      "nome": "META_adicionar_pressao_nao_reduz_gravidade",
      "tipo": "metamorfico",
      "descricao": "Mudar pressao_tempo de false para true mantendo tudo igual não pode manter P-G (deve migrar para P-D)",
      "etapa": 3,
      "input_base": {
        "avaliacao_correta": false,
        "capacidade_sensorial": true,
        "conhecimento_adequado": true,
        "pressao_tempo_excessiva": false,
        "informacao_ilusoria_ambigua": false,
        "informacao_disponivel_correta": true
      },
      "input_modificado": {
        "avaliacao_correta": false,
        "capacidade_sensorial": true,
        "conhecimento_adequado": true,
        "pressao_tempo_excessiva": true,
        "informacao_ilusoria_ambigua": false,
        "informacao_disponivel_correta": true
      },
      "relacao": "resultado_base == 'P-G' && resultado_modificado == 'P-D'"
    },
    {
      "nome": "META_OB_vs_OC_rotina",
      "tipo": "metamorfico",
      "descricao": "Mudar violacao_rotina de false para true deve migrar O-C para O-B",
      "etapa": 4,
      "input_base": {
        "objetivo_consistente_normas": false,
        "violacao_rotina": false
      },
      "input_modificado": {
        "objetivo_consistente_normas": false,
        "violacao_rotina": true
      },
      "relacao": "resultado_base == 'O-C' && resultado_modificado == 'O-B'"
    }
  ],

