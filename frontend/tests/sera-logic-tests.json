{
  "unit_tests": [
    {
      "nome": "OBJ_sem_falha",
      "etapa": 4,
      "descricao": "Objetivo consistente com normas e conservativo → nenhuma falha",
      "inputs": {
        "objetivo_consistente_normas": true,
        "objetivo_conservativo": true
      },
      "esperado": { "codigo": "O-A" }
    },
    {
      "nome": "OBJ_violacao_rotineira",
      "etapa": 4,
      "descricao": "Inconsistente com normas + evidência de habitualidade → O-B",
      "inputs": {
        "objetivo_consistente_normas": false,
        "violacao_rotina": true
      },
      "esperado": { "codigo": "O-B" }
    },
    {
      "nome": "OBJ_violacao_excepcional",
      "etapa": 4,
      "descricao": "Inconsistente com normas + primeira vez, sem habitualidade → O-C",
