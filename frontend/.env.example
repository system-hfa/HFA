# Supabase (client + server)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role: obrigatório para rotas /api (events, analyses, extract-document) no servidor
SUPABASE_SERVICE_ROLE_KEY=

# API legada (FastAPI) para rotas ainda não migradas, ex.: /auth/*, /actions/*
# Deixe vazio para usar apenas as rotas SERA em /api na própria Vercel.
NEXT_PUBLIC_API_URL=

# LLM — configure o provedor em lib/sera/llm.ts (AI_PROVIDER, chaves e modelos)
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# etc.
