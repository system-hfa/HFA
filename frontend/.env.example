# Supabase (client + server)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role: obrigatório para rotas /api (events, analyses, extract-document) no servidor
SUPABASE_SERVICE_ROLE_KEY=

# Opcional: pode colocar as mesmas variáveis na raiz do monorepo em ../.env
# O next.config.ts carrega frontend/.env e ../.env com override=false (não sobrescreve .env.local).

# LLM (rotas devolvem HTTP 503 com mensagem clara se faltar a chave do provedor ativo)
# AI_PROVIDER=deepseek | openai | anthropic | google | groq
AI_PROVIDER=
DEEPSEEK_API_KEY=

# Outros provedores (opcional: preencha para habilitar)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GROQ_API_KEY=

# App (mantido para compatibilidade; este projeto pode ou não usar)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
